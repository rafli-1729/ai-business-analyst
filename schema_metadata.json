      "description": "Primary LLM-friendly analytical serving table. It denormalizes order, item, customer, seller, product, payment, review, logistics, geography, and feature-engineered metrics.",
      "grain": "One row per order item.",
      "preferred_for": [
        "Default table for business analytics questions",
        "Text-to-SQL and LLM-powered analysis",
        "Detailed revenue, delivery, customer, seller, product, payment, and geography analysis",
        "Dashboard serving without repeated multi-table joins"
      ],
      "columns": [
        {
          "name": "order_id",
          "description": "Order identifier.",
          "semantic_type": "identifier"
        },
        {
          "name": "order_item_id",
          "description": "Item sequence number inside an order.",
          "semantic_type": "identifier"
        },
        {
          "name": "product_category_name",
          "description": "Business-friendly product category, preferring English translation.",
          "semantic_type": "categorical"
        },
        {
          "name": "customer_state",
          "description": "Customer Brazilian state abbreviation.",
          "semantic_type": "location"
        },
        {
          "name": "seller_state",
          "description": "Seller Brazilian state abbreviation.",
          "semantic_type": "location"
        },
        {
          "name": "purchase_month_start_date",
          "description": "Month of order purchase.",
          "semantic_type": "date"
        },
        {
          "name": "order_item_revenue",
          "description": "Item price excluding freight.",
          "semantic_type": "metric"
        },
        {
          "name": "order_item_shipping_cost",
          "description": "Shipping cost for the item.",
          "semantic_type": "metric"
        },
        {
          "name": "total_order_item_cost",
          "description": "Item price plus freight value.",
          "semantic_type": "metric"
        },
        {
          "name": "customer_satisfaction_score",
          "description": "Average order review score attached to the item, named for business interpretation.",
          "semantic_type": "metric"
        },
        {
          "name": "delivery_distance_km",
          "description": "Haversine distance between customer and seller ZIP prefix coordinates.",
