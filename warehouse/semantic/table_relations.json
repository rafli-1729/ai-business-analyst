{
  "schema_version": "v2",

  "tables": [

    {
      "table_name": "gold.sales_summary",
      "layer": "gold",
      "description": "Daily business sales performance summary mart.",
      "grain": "One row per purchase_date.",
      "primary_dimensions": [
        "purchase_date"
      ],
      "primary_metrics": [
        "total_revenue",
        "total_orders",
        "total_customers",
        "total_items",
        "average_order_value",
        "average_freight_value"
      ],
      "preferred_for": [
        "trend_analysis",
        "executive_summary",
        "growth_analysis"
      ],
      "columns": [
        {
          "name": "purchase_date",
          "semantic_type": "date",
          "format": "YYYY-MM-DD",
          "description": "Purchase date at daily grain."
        },
        {
          "name": "total_revenue",
          "semantic_type": "metric",
          "unit": "BRL",
          "description": "Total successful payment revenue."
        },
        {
          "name": "total_orders",
          "semantic_type": "metric",
          "description": "Total distinct orders."
        },
        {
          "name": "total_customers",
          "semantic_type": "metric",
          "description": "Total unique customers."
        },
        {
          "name": "total_items",
          "semantic_type": "metric",
          "description": "Total items sold."
        },
        {
          "name": "average_order_value",
          "semantic_type": "metric",
          "unit": "BRL",
          "description": "Average payment value per order."
        },
        {
          "name": "average_freight_value",
          "semantic_type": "metric",
          "unit": "BRL",
          "description": "Average freight cost per item."
        }
      ]
    },

    {
