{
  "schema_version": "v3",
  "tables": [
    {
      "table_name": "gold.fact_sales_items",
      "layer": "gold",
      "description": "One row per item sold. Primary table for revenue and product analysis.",
      "columns": [
        {"name": "order_item_key", "semantic_type": "identifier"},
        {"name": "order_id", "semantic_type": "identifier"},
        {"name": "product_category_name", "semantic_type": "dimension"},
        {"name": "price", "semantic_type": "metric"},
        {"name": "freight_value", "semantic_type": "metric"},
        {"name": "total_value", "semantic_type": "metric", "description": "Price + Freight"},
        {"name": "customer_state", "semantic_type": "location"},
        {"name": "order_purchase_timestamp", "semantic_type": "timestamp"}
      ]
    },
    {
      "table_name": "gold.fact_order_fulfillment",
      "layer": "gold",
      "description": "One row per order. Primary table for delivery performance and satisfaction.",
      "columns": [
        {"name": "order_id", "semantic_type": "identifier"},
        {"name": "delivery_days_actual", "semantic_type": "metric"},
        {"name": "is_late_delivery", "semantic_type": "boolean"},
        {"name": "review_score", "semantic_type": "metric"}
      ]
    },
    {
      "table_name": "gold.mart_customer_behavior",
      "layer": "gold",
      "description": "One row per unique customer. Primary table for retention and LTV.",
      "columns": [
        {"name": "customer_unique_id", "semantic_type": "identifier"},
        {"name": "total_lifetime_value", "semantic_type": "metric"},
        {"name": "total_orders", "semantic_type": "metric"},
        {"name": "is_repeat_customer", "semantic_type": "boolean"}
      ]
    },
    {
      "table_name": "gold.mart_monthly_performance",
      "layer": "gold",
      "description": "High level monthly trends.",
      "columns": [
        {"name": "month_start_date", "semantic_type": "date"},
        {"name": "total_revenue", "semantic_type": "metric"},
        {"name": "total_orders", "semantic_type": "metric"}
      ]
    }
  ]
}
